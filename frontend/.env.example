# Public API base URL used by browser requests and Socket.IO
# Dev example:
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Prod example:
# NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
# If frontend and backend share one domain with Nginx reverse proxy (/api, /socket.io),
# you can leave NEXT_PUBLIC_API_BASE_URL empty to use same-origin requests.
